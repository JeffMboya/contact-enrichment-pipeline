# Required for live enrichment (Stages 2-3).
# Stages 0/1/4/5 run without keys, so you can build and test offline.
SERPER_API_KEY=
ANTHROPIC_API_KEY=

# Optional overrides (defaults shown)
INPUT_FILE=sample_invoices.xlsx
OUTPUT_FILE=output/enriched_output.xlsx
CACHE_DIR=cache
MAX_SERPER_CALLS_PER_ROW=6
# The invoicing client's domain(s) — never enriched as the debtor
CREDITOR_DOMAINS=fedex.com
# Override the company-resolution judge with a single stronger model (e.g.
# claude-opus-4-8). Unset = default cheap-first ladder (Haiku, Sonnet on low
# confidence). The Full name classifier always stays on Haiku.
# RESOLUTION_MODEL=claude-opus-4-8
